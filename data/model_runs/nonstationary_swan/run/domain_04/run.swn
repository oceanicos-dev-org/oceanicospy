$ Header --------------------------------------------
PROJECT 'Non-stationary case for San Andres' '2'
'Example non-stat'
$
$ Computational mesh -----------------------------------
SET NAUT
MODE NONSTAT TWOD
COORD SPHE CCM
CGRID REG 278.28 12.5 0 0.055 0.055 243 243 CIRCLE 36 0.04 1
$
$ Bathymetry --------------------------------------------
INP BOT REG 278.28 12.5 0 243 243 0.000225 0.000225 EXC -9999.
READ BOT 1 '../../input/domain_04/Cal_bat_soundbay_25m.bot' 1 FREE
$
$ Bottom friction ----------------------------------------
INP FR REG 278.28 12.5 0 243 243 0.000225 0.000225 EXC -9.
READ FR 1 '../../input/domain_04/kn_soundbay_25m.fric' 3 FREE
$
$ Wind (spatial, time-varying) --------------------------
INP WIND REG 278 12.3 0. 24 24 0.025 0.025
READ WIND 1 '../../input/domain_01/winds.wnd' 3 FREE
$
$ Water level -------------------------------------------
INP WLEV REG 278.28 12.5 0. 243 243 0.000225 0.000225 EXC -9999.
READ WLEV 1 '../../input/domain_01/water_levels.wl' 3 FREE
$
$ Initial conditions-------------------------------------
INIT DEF
$
$ Boundary conditions ------------------------------------
BOU SHAP JON PEAK
BOUN NEST 'child02_04.NEST' CLOSED
$
$ Physics ------------------------------------------------
GEN3 JANS
QUAD
TRI
BRE
FRIC MAD
DIFFR
$ Numerics ----------------------------------------------
NUM STOPC 0 0.01 0.001 101 NONSTAT mxitns=10
PROP BSBT
$
$ Output -------------------------------------------------
BLOCK 'COMPGRID' NOHEAD 'wave_field.mat' LAY 3 HSIGN TPS TM01 TM02 OUTPUT 20230512.000000 60 MIN
POINTS 'out' FILE 'points.loc'
TABLE 'out' HEADER 'PointSWAN.out' TIME XP YP DEP WIND HSIGN TPS TM01 TM02 DIR OUTPUT 20230512.000000 60 MIN
SPEC 'out' SPEC2D ABS L 'SpecSWAN.out' OUTPUT 20230512.000000 60 MIN
$
$ Nest output --------------------------------------------
$
$ Final --------------------------------------------------
TEST 1, 0
COMP NONSTAT 20230509.000000 10 MIN 20230531.230000
STOP

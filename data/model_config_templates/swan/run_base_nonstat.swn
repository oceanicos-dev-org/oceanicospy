$ Header --------------------------------------------
PROJECT '$name' '$case_number'
'$case_description'
$
$ Computational mesh -----------------------------------
SET NAUT
MODE $stat_label TWOD
COORD SPHE CCM
CGRID REG $lon_ll_corner $lat_ll_corner 0 $x_extent $y_extent $nx $ny CIRCLE 36 0.04 1
$
$ Bathymetry --------------------------------------------
INP BOT REG $lon_ll_corner_bot $lat_ll_corner_bot 0 $nx_bot $ny_bot $dx_bot $dy_bot EXC -9999.
READ BOT 1 '$bathy_file' 1 FREE
$
$ Bottom friction ----------------------------------------
INP FR REG $lon_ll_corner_fric $lat_ll_corner_fric 0 $nx_fric $ny_fric $dx_fric $dy_fric EXC -9.
READ FR 1 '$friction_file' 3 FREE
$
$ Wind (spatial, time-varying) --------------------------
INP WIND REG $lon_ll_corner_wind $lat_ll_corner_wind 0. $nx_wind $ny_wind $dx_wind $dy_wind
READ WIND 1 '$winds_file' 3 FREE
$
$ Water level -------------------------------------------
INP WLEV REG $lon_ll_corner_wl $lat_ll_corner_wl 0. $nx_wl $ny_wl $dx_wl $dy_wl EXC -9999.
READ WLEV 1 '$wl_file' 3 FREE
$
$ Initial conditions-------------------------------------
INIT DEF
$
$ Boundary conditions ------------------------------------
BOU SHAP JON PEAK
$boundaries_line
$
$ Physics ------------------------------------------------
$genmode $diss_form $cds1 $delta
QUAD
TRI
BRE
FRIC MAD
DIFFR
$ Numerics ----------------------------------------------
NUM STOPC 0 0.01 0.001 101 NONSTAT mxitns=10
PROP BSBT
$
$ Output -------------------------------------------------
BLOCK 'COMPGRID' NOHEAD 'wave_field.mat' LAY 3 HSIGN TPS TM01 TM02 DISSIP DISBOT DISWCAP REDQUAD REDTRIAD OUTPUT $ini_output_date $output_res_min MIN
POINTS 'out' FILE 'points.loc'
TABLE 'out' HEADER 'SalidasSWAN.out' TIME XP YP DEP WIND HSIGN TPS TM01 TM02 DIR OUTPUT $ini_output_date $output_res_min MIN
SPEC 'out' SPEC2D ABS L 'SpecSWAN.out' OUTPUT $ini_output_date $output_res_min MIN
$
$ Nest output (removed for non-nested domains by write_nest_section) --
NGRID '$nest_id' $child_lon_ll_corner $child_lat_ll_corner 0 $child_x_extent $child_y_extent $child_nx $child_ny
NESTOUT '$nest_id' '$nest_grid_file' OUTPUT $ini_nest_date $output_res_min MIN
$
$ Final --------------------------------------------------
TEST 1, 0
$string_comp
STOP
